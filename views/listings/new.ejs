<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add a place</title>
</head>
<body>
    <h3>Add a new place</h3>
    <form method="POST" action="/listings">
        <input type="text" placeholder="Enter the title" name="listing[title]">
        <br><br>
        <textarea placeholder="Enter the description"name="listing[description]"></textarea>
        <br><br>
        <input type="text" placeholder="Enter image url "name="listing[image]">
        <br><br>
        <input type="number" placeholder="Enter price "name="listing[price]">
        <br><br>
        <input type="text" placeholder="Enter location "name="listing[location]">
        <br><br>
        <input type="text" placeholder="Enter country "name="listing[country]">
        <br><br>
        <button>Add</button>
    </form>
</body>
</html>